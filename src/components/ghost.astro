---
// src/components/ghost.astro
// Fantôme simple qui utilise les filtres thématiques globaux

import OptimizeImage from './optimize_image.astro';

export interface Props {
  className?: string;
  style?: string;
}

const { 
  className = '',
  style = ''
} = Astro.props;
---

<div 
  class={`bonhommes ${className}`}
  style={style}
>
  <OptimizeImage 
    src="/src/assets/ghost500x500.webp"
    alt="ooOOOOooo" 
    widths={[125]}
    class="ghost-img theme-filtered"
    loading="lazy"
    transition:name="ghost"
  />
</div>